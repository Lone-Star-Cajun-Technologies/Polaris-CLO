{
  "name": "polaris-run-chain",
  "steps": [
    "01-orient-cluster",
    "02-prepare-branch",
    "03-select-child",
    "04-execute-child",
    "05-validate-child",
    "06-commit-and-update-linear",
    "07-decide-continuation",
    "08-final-delivery"
  ],
  "loop_re_entry": "03-select-child",
  "terminal_steps": ["08-final-delivery"],
  "polaris_calls": {
    "06-commit-and-update-linear": ["polaris map update --changed"],
    "07-decide-continuation": ["polaris loop continue"],
    "08-final-delivery": ["polaris finalize"]
  }
}
