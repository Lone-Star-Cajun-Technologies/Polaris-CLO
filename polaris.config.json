{
  "orchestration": {
    "mode": "auto",
    "auto_finalize": true,
    "notification_format": "terse"
  },
  "execution": {
    "adapter": "terminal-cli",
    "providers": {
      "devin": {
        "command": "devin",
        "args": [
          "--permission-mode",
          "bypass",
          "-p",
          "{{worker_prompt}}"
        ]
      },
      "claude": {
        "command": "env",
        "args": [
          "CLAUDE_CODE_SUBPROCESS_ENV_SCRUB=0",
          "claude",
          "--print",
          "--permission-mode",
          "bypassPermissions",
          "--allowedTools",
          "Read",
          "Write",
          "Edit",
          "Bash(git *)",
          "--",
          "{{worker_prompt}}"
        ]
      },
      "codex": {
        "command": "codex",
        "args": [
          "{{worker_prompt}}"
        ]
      },
      "gemini": {
        "command": "gemini",
        "args": [
          "--prompt",
          "{{worker_prompt}}"
        ]
      },
      "copilot": {
        "command": "copilot",
        "args": [
          "-p",
          "{{worker_prompt}}",
          "--autopilot",
          "--allow-all-tools"
        ]
      },
      "kiro": {
        "command": "kiro-cli",
        "args": [
          "chat",
          "--no-interactive",
          "--trust-all-tools",
          "--agent",
          "default",
          "--effort",
          "medium",
          "{{worker_prompt}}"
        ]
      },
      "coderabbit": {
        "command": "coderabbit",
        "args": [
          "review",
          "--agent"
        ]
      },
      "custom": {
        "command": "$POLARIS_AGENT",
        "args": [
          "{{worker_prompt}}"
        ]
      }
    },
    "allowCrossAgentFallback": false,
    "providerPolicy": {
      "worker": {
        "providers": [
          "devin",
          "copilot",
          "codex",
          "kiro"
        ],
        "allowNativeSubagent": false
      },
      "orchestrator": {
        "providers": [
          "codex",
          "copilot"
        ],
        "allowNativeSubagent": false
      },
      "analyst": {
        "providers": [
          "claude",
          "codex"
        ],
        "allowNativeSubagent": true
      },
      "librarian": {
        "providers": [
          "codex",
          "devin",
          "copilot",
          "claude"
        ]
      },
      "finalizer": {
        "providers": [
          "copilot"
        ]
      },
      "foreman": {
        "providers": [
          "codex"
        ]
      }
    }
  },
  "budget": {
    "mode": "fixed-cap",
    "max_children": 6,
    "stop_on_fail": false
  },
  "simplicity": {
    "mode": "full"
  },
  "docs": {
    "ingestBatchSize": 10
  },
  "tracker": {
    "adapter": "linear",
    "linear": {
      "enabled": true,
      "teamId": "Polaris",
      "projectId": "Polaris Core Runtime"
    }
  },
  "qc": {
    "enabled": true,
    "defaultTrigger": "completed-cluster",
    "providers": {
      "coderabbit": {
        "name": "coderabbit",
        "mode": "local",
        "trigger": "completed-cluster",
        "capabilities": ["diff-review"]
      }
    },
    "severityThresholds": {
      "block": "high",
      "repair": "medium",
      "followUp": "low"
    },
    "repairRouting": "route"
  },
  "version": "1.0",
  "providers": {
    "compactionProviders": [
      "caveman"
    ],
    "repoAnalysis": {
      "preferred": "polaris-graph"
    }
  }
}
