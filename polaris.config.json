{
  "orchestration": {
    "mode": "auto",
    "auto_finalize": false,
    "notification_format": "terse"
  },
  "execution": {
    "adapter": "terminal-cli",
    "providers": {
      "claude": {
        "command": "claude",
        "args": ["--print", "{{packet_json}}"]
      },
      "codex": {
        "command": "codex",
        "args": ["{{packet_json}}"]
      },
      "gemini": {
        "command": "gemini",
        "args": ["--prompt", "{{packet_json}}"]
      },
      "copilot": {
        "command": "copilot",
        "args": ["-p", "{{packet_json}}", "--autopilot", "--allow-all-tools"]
      },
      "custom": {
        "command": "$POLARIS_AGENT",
        "args": ["{{packet_json}}"]
      }
    },
    "rotation": ["claude", "codex", "gemini", "copilot"],
    "allowCrossAgentFallback": false
  },
  "tracker": {
   "adapter": "linear",
   "linear": {
      "enabled": true,
      "teamId": "Polaris",
      "projectId": "Polaris Core Runtime"
  }
}
}
