{
  "orchestration": {
    "mode": "auto",
    "auto_finalize": false,
    "notification_format": "terse"
  },
  "execution": {
    "adapter": "terminal-cli",
    "providers": {
      "claude": {
        "command": "claude",
        "args": ["--print", "--dangerously-skip-permissions", "{{worker_prompt}}"]
      },
      "codex": {
        "command": "codex",
        "args": ["{{worker_prompt}}"]
      },
      "gemini": {
        "command": "gemini",
        "args": ["--prompt", "{{worker_prompt}}"]
      },
      "copilot": {
        "command": "copilot",
        "args": ["-p", "{{worker_prompt}}", "--autopilot", "--allow-all-tools"]
      },
      "custom": {
        "command": "$POLARIS_AGENT",
        "args": ["{{worker_prompt}}"]
      }
    },
    "allowCrossAgentFallback": false,
    "providerPolicy": {
      "worker": {
        "providers": ["copilot", "codex"],
        "allowNativeSubagent": false
      },
      "orchestrator": {
        "providers": ["codex", "copilot"],
        "allowNativeSubagent": false
      },
      "analyst": {
        "providers": ["claude", "codex"],
        "allowNativeSubagent": true
      },
      "librarian": {
        "providers": ["claude","codex","gemini","copilot"]
      },
      "finalizer": {
        "providers": ["copilot"]
      }
    }
  },
  "budget": {
    "mode": "fixed-cap",
    "max_children": 6,
    "stop_on_fail": false
  },
  "docs": {
    "ingestBatchSize": 10
  },
  "tracker": {
   "adapter": "linear",
   "linear": {
      "enabled": true,
      "teamId": "Polaris",
      "projectId": "Polaris Core Runtime"
  }
}
}
