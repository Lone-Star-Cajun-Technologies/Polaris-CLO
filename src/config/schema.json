{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PolarisConfig",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "string",
      "default": "1.0"
    },
    "repo": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "sourceRoots": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["src"]
        },
        "docsRoots": {
          "type": "array",
          "items": { "type": "string" }
        },
        "taskchainRoots": {
          "type": "array",
          "items": { "type": "string" }
        },
        "generatedRoots": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sidecarOutputPath": {
          "type": "string",
          "default": ".polaris/map"
        }
      }
    },
    "map": {
      "type": "object",
      "properties": {
        "confidenceThreshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.75
        },
        "autoWriteAbove": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.85
        },
        "reviewRequiredBelow": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.75
        },
        "inferenceRules": {
          "type": "array",
          "items": { "type": "string" }
        },
        "onLowConfidence": {
          "type": "string",
          "enum": ["warn", "fail"],
          "default": "warn"
        }
      }
    },
    "loop": {
      "type": "object",
      "properties": {
        "bootstrapOutputPath": {
          "type": "string",
          "default": ".polaris/bootstrap"
        },
        "analyzeImplBoundaryEnforced": {
          "type": "boolean",
          "default": true
        },
        "sessionTerminationMode": {
          "type": "string",
          "enum": ["emit-marker", "exit-0"],
          "default": "emit-marker"
        }
      }
    },
    "graph": {
      "type": "object",
      "properties": {
        "outputPath": {
          "type": "string",
          "default": ".polaris/graph"
        },
        "invalidationTriggers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["repo-change", "config-change"]
          },
          "default": ["repo-change", "config-change"]
        }
      }
    },
    "execution": {
      "type": "object",
      "properties": {
        "adapter": {
          "type": "string",
          "enum": ["agent-subtask", "terminal-cli", "ci", "ssh", "remote-worker", "cross-agent"]
        },
        "providers": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "command": { "type": "string" },
              "args": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "required": ["command"]
          }
        },
        "rotation": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowCrossAgentFallback": {
          "type": "boolean",
          "default": false
        },
        "roles": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "orchestrator": { "$ref": "#/definitions/roleExecutionConfig" },
            "startup": { "$ref": "#/definitions/roleExecutionConfig" },
            "worker": { "$ref": "#/definitions/roleExecutionConfig" },
            "analyst": { "$ref": "#/definitions/roleExecutionConfig" },
            "analysis": { "$ref": "#/definitions/roleExecutionConfig" },
            "repair": { "$ref": "#/definitions/roleExecutionConfig" },
            "librarian": { "$ref": "#/definitions/roleExecutionConfig" },
            "docs": { "$ref": "#/definitions/roleExecutionConfig" },
            "finalizer": { "$ref": "#/definitions/roleExecutionConfig" }
          }
        },
        "providerPolicy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "orchestrator": { "$ref": "#/definitions/roleProviderPolicy" },
            "startup": { "$ref": "#/definitions/roleProviderPolicy" },
            "worker": { "$ref": "#/definitions/roleProviderPolicy" },
            "analyst": { "$ref": "#/definitions/roleProviderPolicy" },
            "analysis": { "$ref": "#/definitions/roleProviderPolicy" },
            "repair": { "$ref": "#/definitions/roleProviderPolicy" },
            "librarian": { "$ref": "#/definitions/roleProviderPolicy" },
            "docs": { "$ref": "#/definitions/roleProviderPolicy" },
            "finalizer": { "$ref": "#/definitions/roleProviderPolicy" }
          }
        }
      }
    },
    "finalize": {
      "type": "object",
      "properties": {
        "targetBranch": {
          "type": "string",
          "default": "main"
        },
        "prDraft": {
          "type": "boolean",
          "default": true
        },
        "runChecks": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "requireMapValidation": {
          "type": "boolean",
          "default": true
        },
        "requireSchemaValidation": {
          "type": "boolean",
          "default": true
        },
        "archiveRunSnapshot": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "tracker": {
      "type": "object",
      "properties": {
        "adapter": {
          "type": "string",
          "enum": ["linear", "mcp-bridge", "local", "spec"],
          "default": "linear"
        },
        "lifecyclePolicy": {
          "type": "object",
          "properties": {
            "childOnDispatch": {
              "type": "string",
              "enum": ["backlog", "in_progress", "in_review", "done", "blocked", "cancelled", "no_status_change"],
              "default": "in_progress"
            },
            "childOnValidationPassed": {
              "type": "string",
              "enum": ["backlog", "in_progress", "in_review", "done", "blocked", "cancelled", "no_status_change"],
              "default": "in_review"
            },
            "childOnMerged": {
              "type": "string",
              "enum": ["backlog", "in_progress", "in_review", "done", "blocked", "cancelled", "no_status_change"],
              "default": "done"
            },
            "parentOnAllChildrenComplete": {
              "type": "string",
              "enum": ["backlog", "in_progress", "in_review", "done", "blocked", "cancelled", "no_status_change"],
              "default": "in_review"
            },
            "parentOnDeliveryMerged": {
              "type": "string",
              "enum": ["backlog", "in_progress", "in_review", "done", "blocked", "cancelled", "no_status_change"],
              "default": "done"
            },
            "childOnTriageRequired": {
              "type": "string",
              "enum": ["backlog", "in_progress", "in_review", "done", "blocked", "cancelled", "no_status_change"],
              "default": "blocked"
            },
            "providerFailureBeforeWork": {
              "type": "string",
              "enum": ["backlog", "in_progress", "in_review", "done", "blocked", "cancelled", "no_status_change"],
              "default": "no_status_change"
            }
          }
        },
        "linear": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "teamId": { "type": "string" },
            "projectId": { "type": "string" }
          }
        },
        "mcpBridge": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "teamId": { "type": "string" },
            "projectId": { "type": "string" }
          }
        }
      }
    },
    "integrations": {
      "type": "object",
      "properties": {
        "github": {
          "type": "object",
          "properties": {
            "owner": { "type": "string" },
            "repo": { "type": "string" }
          }
        }
      }
    }
  },
  "definitions": {
    "roleExecutionConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "adapter": {
          "type": "string",
          "enum": ["agent-subtask", "terminal-cli", "ci", "ssh", "remote-worker", "cross-agent"]
        },
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "command": { "type": "string" },
        "args": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "roleProviderPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "providers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowNativeSubagent": { "type": "boolean" },
        "noFallback": { "type": "boolean" }
      },
      "required": ["providers"]
    }
  }
}
