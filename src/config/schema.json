{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PolarisConfig",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "string",
      "default": "1.0"
    },
    "repo": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "sourceRoots": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["src"]
        },
        "docsRoots": {
          "type": "array",
          "items": { "type": "string" }
        },
        "taskchainRoots": {
          "type": "array",
          "items": { "type": "string" }
        },
        "generatedRoots": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sidecarOutputPath": {
          "type": "string",
          "default": ".polaris/map"
        }
      }
    },
    "map": {
      "type": "object",
      "properties": {
        "confidenceThreshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.75
        },
        "autoWriteAbove": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.85
        },
        "reviewRequiredBelow": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.75
        },
        "inferenceRules": {
          "type": "array",
          "items": { "type": "string" }
        },
        "onLowConfidence": {
          "type": "string",
          "enum": ["warn", "fail"],
          "default": "warn"
        }
      }
    },
    "loop": {
      "type": "object",
      "properties": {
        "bootstrapOutputPath": {
          "type": "string",
          "default": ".polaris/bootstrap"
        },
        "analyzeImplBoundaryEnforced": {
          "type": "boolean",
          "default": true
        },
        "sessionTerminationMode": {
          "type": "string",
          "enum": ["emit-marker", "exit-0"],
          "default": "emit-marker"
        }
      }
    },
    "graph": {
      "type": "object",
      "properties": {
        "outputPath": {
          "type": "string",
          "default": ".polaris/graph"
        },
        "invalidationTriggers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["repo-change", "config-change"]
          },
          "default": ["repo-change", "config-change"]
        }
      }
    },
    "execution": {
      "type": "object",
      "properties": {
        "adapter": {
          "type": "string",
          "enum": ["agent-subtask", "terminal-cli", "ci", "ssh", "remote-worker", "cross-agent"]
        },
        "providers": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "command": { "type": "string" },
              "args": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "required": ["command"]
          }
        },
        "rotation": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowCrossAgentFallback": {
          "type": "boolean",
          "default": false
        },
        "roles": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "orchestrator": { "$ref": "#/definitions/roleExecutionConfig" },
            "startup": { "$ref": "#/definitions/roleExecutionConfig" },
            "worker": { "$ref": "#/definitions/roleExecutionConfig" },
            "foreman": { "$ref": "#/definitions/roleExecutionConfig" },
            "analyst": { "$ref": "#/definitions/roleExecutionConfig" },
            "analysis": { "$ref": "#/definitions/roleExecutionConfig" },
            "repair": { "$ref": "#/definitions/roleExecutionConfig" },
            "librarian": { "$ref": "#/definitions/roleExecutionConfig" },
            "docs": { "$ref": "#/definitions/roleExecutionConfig" },
            "finalizer": { "$ref": "#/definitions/roleExecutionConfig" }
          }
        },
        "providerPolicy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "orchestrator": { "$ref": "#/definitions/roleProviderPolicy" },
            "startup": { "$ref": "#/definitions/roleProviderPolicy" },
            "worker": { "$ref": "#/definitions/roleProviderPolicy" },
            "foreman": { "$ref": "#/definitions/roleProviderPolicy" },
            "analyst": { "$ref": "#/definitions/roleProviderPolicy" },
            "analysis": { "$ref": "#/definitions/roleProviderPolicy" },
            "repair": { "$ref": "#/definitions/roleProviderPolicy" },
            "librarian": { "$ref": "#/definitions/roleProviderPolicy" },
            "docs": { "$ref": "#/definitions/roleProviderPolicy" },
            "finalizer": { "$ref": "#/definitions/roleProviderPolicy" }
          }
        },
        "routerPolicy": {
          "$ref": "#/definitions/workerRouterPolicyConfig"
        }
      }
    },
    "finalize": {
      "type": "object",
      "properties": {
        "targetBranch": {
          "type": "string",
          "default": "main"
        },
        "prDraft": {
          "type": "boolean",
          "default": true
        },
        "runChecks": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "requireMapValidation": {
          "type": "boolean",
          "default": true
        },
        "requireSchemaValidation": {
          "type": "boolean",
          "default": true
        },
        "archiveRunSnapshot": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "tracker": {
      "type": "object",
      "properties": {
        "adapter": {
          "type": "string",
          "enum": ["linear", "mcp-bridge", "local"],
          "default": "linear"
        },
        "lifecyclePolicy": {
          "type": "object",
          "properties": {
            "childOnDispatch": {
              "type": "string",
              "enum": ["backlog", "in_progress", "in_review", "done", "blocked", "cancelled", "no_status_change"],
              "default": "in_progress"
            },
            "childOnValidationPassed": {
              "type": "string",
              "enum": ["backlog", "in_progress", "in_review", "done", "blocked", "cancelled", "no_status_change"],
              "default": "in_review"
            },
            "childOnMerged": {
              "type": "string",
              "enum": ["backlog", "in_progress", "in_review", "done", "blocked", "cancelled", "no_status_change"],
              "default": "done"
            },
            "parentOnAllChildrenComplete": {
              "type": "string",
              "enum": ["backlog", "in_progress", "in_review", "done", "blocked", "cancelled", "no_status_change"],
              "default": "in_review"
            },
            "parentOnDeliveryMerged": {
              "type": "string",
              "enum": ["backlog", "in_progress", "in_review", "done", "blocked", "cancelled", "no_status_change"],
              "default": "done"
            },
            "childOnTriageRequired": {
              "type": "string",
              "enum": ["backlog", "in_progress", "in_review", "done", "blocked", "cancelled", "no_status_change"],
              "default": "blocked"
            },
            "providerFailureBeforeWork": {
              "type": "string",
              "enum": ["backlog", "in_progress", "in_review", "done", "blocked", "cancelled", "no_status_change"],
              "default": "no_status_change"
            }
          }
        },
        "linear": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "teamId": { "type": "string" },
            "projectId": { "type": "string" }
          }
        },
        "mcpBridge": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "teamId": { "type": "string" },
            "projectId": { "type": "string" }
          }
        }
      }
    },
    "integrations": {
      "type": "object",
      "properties": {
        "github": {
          "type": "object",
          "properties": {
            "owner": { "type": "string" },
            "repo": { "type": "string" }
          }
        }
      }
    },
    "qc": {
      "$ref": "#/definitions/qcConfig"
    }
  },
  "definitions": {
    "roleExecutionConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "adapter": {
          "type": "string",
          "enum": ["agent-subtask", "terminal-cli", "ci", "ssh", "remote-worker", "cross-agent"]
        },
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "command": { "type": "string" },
        "args": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "roleProviderPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "providers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowNativeSubagent": { "type": "boolean" },
        "noFallback": { "type": "boolean" }
      },
      "required": ["providers"]
    },
    "workerRouterPolicyConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaultWorkerPool": { "$ref": "#/definitions/workerPoolLimits" },
        "providerRegistry": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/workerProviderRouterPolicy" }
        },
        "allowCrossProviderFallback": { "type": "boolean" }
      }
    },
    "workerPoolLimits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxActiveWorkers": {
          "type": "integer",
          "minimum": 1
        },
        "maxActiveSlots": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "workerProviderRouterPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eligibleRoles": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["orchestrator", "startup", "worker", "foreman", "analyst", "analysis", "repair", "librarian", "docs", "finalizer"]
          }
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["orchestration", "analysis", "implementation", "repair", "docs", "finalization"]
          }
        },
        "taskTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["startup", "analyze", "impl", "repair", "docs", "finalize"]
          }
        },
        "trustTier": {
          "type": "string",
          "enum": ["sandbox", "standard", "trusted"]
        },
        "costTier": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "quotaPolicy": {
          "type": "string",
          "enum": ["best-effort", "rate-limited", "reserved"]
        },
        "fallbackEligible": { "type": "boolean" },
        "maxActiveSlots": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "qcConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "defaultTrigger": {
          "type": "string",
          "enum": ["pr", "completed-cluster", "child"],
          "default": "completed-cluster"
        },
        "providers": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/qcProviderConfig" }
        },
        "severityThresholds": {
          "$ref": "#/definitions/qcSeverityThresholds"
        },
        "autoFix": {
          "type": "string",
          "enum": ["disabled", "dry-run", "apply"],
          "default": "disabled"
        },
        "repairRouting": {
          "type": "string",
          "enum": ["block", "route", "follow-up", "log"],
          "default": "route"
        },
        "artifactRetention": {
          "$ref": "#/definitions/qcArtifactRetention"
        },
        "routes": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/qcRoutePolicy" }
        }
      }
    },
    "qcProviderConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "mode"],
      "properties": {
        "name": { "type": "string" },
        "mode": {
          "type": "string",
          "enum": ["local", "pr", "metrics-import"]
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["diff-review", "pr-review", "result-parsing", "auto-fix", "metrics-import"]
          }
        },
        "trigger": {
          "type": "string",
          "enum": ["pr", "completed-cluster", "child"]
        },
        "autoFixEligible": { "type": "boolean" },
        "severityMapping": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "info"]
          }
        }
      }
    },
    "qcSeverityThresholds": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "block": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "info"],
          "default": "high"
        },
        "repair": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "info"],
          "default": "medium"
        },
        "followUp": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "info"],
          "default": "low"
        }
      }
    },
    "qcRoutePolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "childLevel": { "type": "boolean" },
        "blockThreshold": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "info"]
        },
        "autoFix": {
          "type": "string",
          "enum": ["disabled", "dry-run", "apply"]
        }
      }
    },
    "qcArtifactRetention": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "retainRawOutput": { "type": "boolean", "default": false },
        "maxRuns": { "type": "integer", "minimum": 1, "default": 10 }
      }
    }
  }
}
