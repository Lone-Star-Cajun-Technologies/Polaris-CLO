{
  "name": "@lsctech/polaris",
  "version": "0.4.4",
  "description": "Polaris — standalone taskchain orchestration framework for governed AI agent workflows",
  "bin": {
    "polaris": "dist/cli/index.js",
    "polaris-cli": "dist/cli/index.js"
  },
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./config": "./dist/config/index.js",
    "./loop": "./dist/loop/index.js",
    "./tracker": "./dist/tracker/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc && rm -rf dist/workspace && cp -r src/workspace dist/workspace && cp .codex/plugins/polaris/skills/polaris-tools/tools.js dist/workspace/.polaris/skills/polaris-tools/tools.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json",
    "test": "vitest run",
    "polaris-cli": "node dist/cli/index.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "ai",
    "agent",
    "orchestration",
    "taskchain",
    "workflow",
    "governance",
    "cli",
    "linear",
    "github",
    "jira"
  ],
  "author": "LSC Technologies <phil.meaux@lsctech.biz>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lone-Star-Cajun-Technologies/Polaris-CLO"
  },
  "homepage": "https://github.com/lsctech/polaris#readme",
  "bugs": {
    "url": "https://github.com/lsctech/polaris/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.0.0",
    "ignore": "^6.0.2",
    "tree-sitter": "^0.22.0",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-c-sharp": "^0.23.5",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-dart": "^1.0.0",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-python": "^0.23.6",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-swift": "^0.7.1",
    "tree-sitter-typescript": "^0.23.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.4.2",
    "vitest": "^3.0.5"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.104.1"
  }
}
